---
import type { Locale } from '../../i18n/index'
import { getLocalePath, useTranslations } from '../../i18n/index'

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t          = useTranslations(locale);
---

<section
  class="section"
  aria-labelledby="referral-title"
  style="background: linear-gradient(135deg, var(--color-bg-surface) 0%, var(--color-bg-elevated) 100%);"
>
  <div class="container">
    <div class="text-center mb-12">
      <span class="section-label">
        🎁 {t.nav.promotions}
      </span>
      <h2 id="referral-title" class="text-headline text-[var(--color-text-primary)] mb-4">
        {t.referral.headline}
      </h2>
      <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto leading-relaxed">
        {t.referral.subline}
      </p>
    </div>

    <!-- 3-step flow -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {[
        { step: '1', icon: '📨', label: t.referral.step1Title, desc: t.referral.step1Desc },
        { step: '2', icon: '🎮', label: t.referral.step2Title, desc: t.referral.step2Desc },
        { step: '3', icon: '💰', label: t.referral.step3Title, desc: t.referral.step3Desc },
      ].map(({ step, icon, label, desc }, idx) => (
        <div class="relative card p-6 text-center">
          {idx < 2 && (
            <div
              class="hidden md:block absolute top-1/2 -translate-y-1/2 right-0 translate-x-1/2 z-10"
              aria-hidden="true"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </div>
          )}
          <div
            class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 text-sm font-bold"
            style="background: var(--color-primary-600); color: var(--color-text-primary);"
            aria-hidden="true"
          >
            {step}
          </div>
          <div class="text-3xl mb-3" aria-hidden="true">{icon}</div>
          <h3 class="font-semibold text-[var(--color-text-primary)] mb-2">{label}</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>

    <!-- Reward highlight -->
    <div
      class="rounded-[var(--radius-2xl)] p-8 md:p-12 text-center"
      style="background: linear-gradient(135deg, var(--color-primary-600)22, var(--color-gold-500)22); border: 1px solid var(--color-gold-500)44;"
    >
      <p class="text-[var(--color-text-muted)] text-sm uppercase tracking-widest mb-2">{t.referral.youEarn}</p>
      <p
        class="text-5xl md:text-6xl font-black mb-2"
        style="background: linear-gradient(135deg, var(--color-gold-400), var(--color-gold-600)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >
        €50
      </p>
      <p class="text-[var(--color-text-secondary)] mb-6">{t.referral.perFriend}</p>
      <a
        href={getLocalePath(locale, '/promotions')}
        class="inline-flex items-center justify-center px-8 py-4 rounded-[var(--radius-xl)] text-sm font-bold text-[var(--color-text-inverse)]"
        style="background: linear-gradient(135deg, var(--color-gold-500), var(--color-gold-600)); box-shadow: var(--shadow-glow-gold);"
      >
        {t.referral.cta}
      </a>
    </div>
  </div>
</section>
