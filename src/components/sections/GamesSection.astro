---
import type { Locale } from '../../i18n/index';
import { useTranslations } from '../../i18n/index';
import { GameCard } from '../widgets/GameCard';
import { getHotGames } from '../../data/games';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t     = useTranslations(locale);
const games = getHotGames(8);
---

<section class="section bg-[var(--color-bg-base)]" aria-labelledby="popular-games-title">
  <div class="container">
    <div class="section-header">
      <div>
        <span class="section-label">{t.sections.popularGames}</span>
        <h2 id="popular-games-title" class="text-headline text-[var(--color-text-primary)]">Popular Right Now</h2>
      </div>
      <a
        href={`/${locale}/games`}
        class="hidden sm:flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary-400)] hover:text-[var(--color-primary-300)] transition-colors"
      >
        {t.sections.viewAll}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4" role="list">
      {games.map((game) => (
        <li>
          <GameCard game={game} locale={locale} />
        </li>
      ))}
    </ul>

    <div class="flex justify-center mt-8">
      <a
        href={`/${locale}/games`}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius-xl)] text-sm font-medium border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-colors"
      >
        {t.sections.viewAll} Games
      </a>
    </div>
  </div>
</section>
