---
import type { Locale } from '../../i18n/index';
import { useTranslations } from '../../i18n/index';
import { GameCard } from '../widgets/GameCard';
import { getLiveGames } from '../../data/games';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t     = useTranslations(locale);
const games = getLiveGames(6);
---

<section
  class="section bg-[var(--color-bg-surface)]"
  aria-labelledby="live-games-title"
  style="background: linear-gradient(180deg, var(--color-bg-surface) 0%, var(--color-bg-base) 100%);"
>
  <div class="container">
    <div class="section-header">
      <div>
        <span class="section-label flex items-center gap-2">
          <span class="live-dot" aria-hidden="true"></span>
          Live Now
        </span>
        <h2 id="live-games-title" class="text-headline text-[var(--color-text-primary)]">{t.sections.liveGames}</h2>
      </div>
      <a
        href={`/${locale}/games/live-casino`}
        class="hidden sm:flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary-400)] hover:text-[var(--color-primary-300)] transition-colors"
      >
        {t.sections.viewAll}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-6 gap-4" role="list">
      {games.map((game) => (
        <li>
          <GameCard game={game} locale={locale} />
        </li>
      ))}
    </ul>
  </div>
</section>
