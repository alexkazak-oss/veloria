---
import { getNavItems } from '../../data/navigation'
import type { Locale } from '../../i18n/index'
import { useTranslations } from '../../i18n/index'
import AppSidebar from './AppSidebar'
import MobileAuthMenu from './MobileAuthMenu'

interface Props {
  locale:  Locale;
  current?: string;
}

const { locale, current = '' } = Astro.props;
const t    = useTranslations(locale);
const nav  = getNavItems(locale);
---

<header id="site-header" class="sticky top-0 z-[var(--z-sticky)] glass border-b border-[var(--color-border)]">
  <div class="container">
    <div class="flex items-center justify-between h-16 gap-2 sm:gap-4">

      <!-- Sidebar trigger -->
      <AppSidebar currentPath={Astro.url.pathname} locale={locale} client:load />

      <!-- Logo -->
      <a href={`/${locale}/`} class="flex items-center gap-2 shrink-0" aria-label="Veloria – Home">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true" class="sm:w-8 sm:h-8">
          <rect width="32" height="32" rx="8" fill="url(#logo-grad)" />
          <path d="M8 9h4l4 10 4-10h4L16 24 8 9z" fill="white" />
          <defs>
            <linearGradient id="logo-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
              <stop stop-color="#7c3aed" />
              <stop offset="1" stop-color="#4c1d95" />
            </linearGradient>
          </defs>
        </svg>
        <span class="font-bold text-base sm:text-lg tracking-tight text-[var(--color-text-primary)]">
          Ve<span class="text-[var(--color-primary-400)]">loria</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1 flex-1 justify-center" aria-label="Main navigation">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded-[var(--radius-lg)] text-sm font-medium transition-colors duration-[var(--transition-fast)] whitespace-nowrap',
              current === item.href
                ? 'text-[var(--color-text-primary)] bg-[var(--color-bg-elevated)]'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-elevated)]',
            ]}
            aria-current={current === item.href ? 'page' : undefined}
          >
            {item.isNew
              ? <span class="flex items-center gap-1.5">{t.nav[item.label.toLowerCase() as keyof typeof t.nav] ?? item.label} <span class="text-[0.55rem] font-bold bg-[var(--color-primary-600)] text-white px-1.5 py-0.5 rounded-full uppercase">New</span></span>
              : (t.nav[item.label.toLowerCase() as keyof typeof t.nav] ?? item.label)
            }
          </a>
        ))}
      </nav>

      <!-- Right actions -->
      <div class="flex items-center gap-1.5 sm:gap-2 shrink-0">
        <!-- Mobile-only: user icon → bottom sheet with Sign In + Register -->
        <MobileAuthMenu locale={locale} client:load />

        <!-- Login: hidden on mobile, visible sm+ -->
        <a
          href={`/${locale}/login/`}
          class="hidden sm:inline-flex items-center px-3 py-1.5 sm:px-4 sm:py-2 text-xs sm:text-sm font-medium rounded-[var(--radius-xl)] text-[var(--color-text-secondary)] border border-[var(--color-border)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-colors duration-[var(--transition-fast)] whitespace-nowrap"
        >
          {t.auth.login}
        </a>
        <!-- Register: hidden on mobile (handled by MobileAuthMenu), visible sm+ -->
        <a
          href={`/${locale}/register/`}
          class="hidden sm:inline-flex items-center px-3 py-1.5 sm:px-4 sm:py-2 text-xs sm:text-sm font-semibold rounded-[var(--radius-xl)] bg-[var(--color-primary-600)] text-white hover:bg-[var(--color-primary-500)] shadow-[var(--shadow-glow-primary)] transition-all duration-[var(--transition-fast)] whitespace-nowrap"
        >
          {t.auth.register}
        </a>
      </div>
    </div>
  </div>
</header>
