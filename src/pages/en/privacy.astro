---
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro'
import type { Locale } from '../../i18n/index'
import PageLayout from '../../layouts/PageLayout.astro'
import { buildSEO } from '../../lib/seo'

const locale = 'en' as Locale;
const seo = buildSEO({
  title      : 'Privacy Policy — Veloria Casino',
  description: 'Veloria Casino Privacy Policy — how we collect, use, and protect your personal data. Demo prototype document.',
  canonical  : 'https://veloria.casino/en/privacy/',
  locale,
  siteName   : 'Veloria Casino',
});
---

<PageLayout {...seo} locale={locale} current="/en/privacy/">
  <div class="container py-8 md:py-14 max-w-3xl">
    <Breadcrumbs items={[{ label: 'Home', href: '/en/' }, { label: 'Privacy Policy', href: '/en/privacy/' }]} locale={locale} />

    <article class="mt-8">
      <h1 class="text-headline text-[var(--color-text-primary)] mb-2">Privacy Policy</h1>
      <p class="text-xs text-[var(--color-text-muted)] mb-8">Last updated: 1 January 2026 · Demo prototype only</p>

      <div class="space-y-8 text-sm text-[var(--color-text-secondary)] leading-relaxed">
        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">1. Data Controller</h2>
          <p>Veloria Entertainment Ltd (hypothetical), a company incorporated in Malta, is the data controller for personal data processed through this website. Contact: privacy@veloria.casino (demo address).</p>
        </section>

        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">2. What Data We Collect</h2>
          <ul class="space-y-1 mt-2">
            {['Name, email address, date of birth, country of residence (registration)', 'Payment method details (type and last four digits only, never full card numbers)', 'IP address, browser type, device information, session timestamps', 'Game history, transaction records, customer support communications', 'Marketing preferences and cookie consent settings'].map((item) => (
              <li class="flex gap-2"><span class="text-[var(--color-primary-400)]" aria-hidden="true">·</span><span>{item}</span></li>
            ))}
          </ul>
        </section>

        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">3. Legal Basis for Processing</h2>
          <p>We process personal data on the basis of: (a) contract performance — to provide the services you signed up for; (b) legal obligation — for fraud prevention, AML/KYC compliance; (c) legitimate interest — for security monitoring; (d) consent — for marketing communications and non-essential cookies.</p>
        </section>

        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">4. How We Use Your Data</h2>
          <p>Your data is used to operate your account, process transactions, provide customer support, prevent fraud and money laundering, comply with regulatory obligations, and (with consent) send you personalised offers.</p>
        </section>

        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">5. Data Sharing</h2>
          <p>We do not sell your personal data. We share data only with: payment processors (for transactions), identity verification services (for KYC), regulatory authorities (when legally required), and analytics/security providers under data processing agreements.</p>
        </section>

        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">6. Data Retention</h2>
          <p>Account data is retained for 5 years after account closure as required by anti-money laundering regulations. Marketing preferences and consent records are retained for 3 years. Log data is retained for 12 months.</p>
        </section>

        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">7. Your Rights</h2>
          <p>You have the right to: access your personal data; rectify inaccurate data; erase data (subject to legal obligations); restrict processing; data portability; object to processing; withdraw consent at any time. Submit requests to privacy@veloria.casino.</p>
        </section>

        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">8. Cookies</h2>
          <p>We use essential, functional, analytics, and marketing cookies. You can manage your cookie preferences at any time via the cookie banner or our Cookie Policy page. Withdrawing consent for non-essential cookies will not affect the service.</p>
        </section>

        <section>
          <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">9. Security</h2>
          <p>All data in transit is protected with 256-bit TLS/SSL encryption. Data at rest is encrypted using AES-256. We undergo annual penetration tests and maintain ISO 27001-aligned security controls.</p>
        </section>
      </div>

      <div class="mt-10 p-4 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)]" role="note">
        <p class="text-xs text-[var(--color-text-muted)]">This Privacy Policy is fictional and part of a UI demo prototype. No real data is collected or processed by Veloria Casino.</p>
      </div>
    </article>
  </div>
</PageLayout>
