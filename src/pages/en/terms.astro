---
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro'
import type { Locale } from '../../i18n/index'
import PageLayout from '../../layouts/PageLayout.astro'
import { buildSEO } from '../../lib/seo'

const locale = 'en' as Locale;
const seo = buildSEO({
  title      : 'Terms & Conditions — Veloria Casino',
  description: 'Read the Veloria Casino Terms and Conditions. These are fictional demo terms for prototype purposes only.',
  canonical  : 'https://veloria.casino/en/terms/',
  locale,
  siteName   : 'Veloria Casino',
  noIndex    : false,
});

const sections = [
  {
    title: '1. General',
    body: 'These Terms and Conditions ("Terms") govern your use of the Veloria Casino website and all services offered therein. By accessing or using the site, you agree to be bound by these Terms. Veloria Casino is a demonstration prototype and does not constitute a licensed gambling operation.',
  },
  {
    title: '2. Eligibility',
    body: 'You must be at least 18 years of age (or the legal gambling age in your jurisdiction, whichever is higher) to use this service. Use of the platform by persons under the permitted age is strictly prohibited. Veloria reserves the right to request proof-of-age documentation at any time.',
  },
  {
    title: '3. Account Registration',
    body: 'To access most features you must create an account. You are responsible for maintaining the confidentiality of your login credentials. You agree to provide accurate, current, and complete information during registration and to update information as necessary. One account per person is permitted.',
  },
  {
    title: '4. Deposits & Withdrawals',
    body: 'All deposits and withdrawals are fictional in this prototype. In a real casino context, funds are held in segregated client accounts and processed within stated timeframes. Withdrawal requests are subject to identity verification and wagering requirements where applicable.',
  },
  {
    title: '5. Bonuses & Promotions',
    body: 'Promotional offers are subject to individual terms including minimum deposit amounts, wagering requirements, game restrictions, and expiry dates. Veloria reserves the right to amend or withdraw any promotion at any time. Abuse of bonus terms may result in account suspension.',
  },
  {
    title: '6. Fair Gaming',
    body: 'All games use certified Random Number Generators (RNG) to ensure fair outcomes. Games are regularly tested by independent third-party auditors. Return-to-player (RTP) percentages are published transparently. In this prototype, all games are simulated.',
  },
  {
    title: '7. Responsible Gaming',
    body: 'We are committed to responsible gaming and offer tools including deposit limits, session time limits, reality checks, and self-exclusion. If you believe you have a gambling problem, please use these tools or contact a support organisation.',
  },
  {
    title: '8. Privacy',
    body: 'Your personal data is processed in accordance with our Privacy Policy. We use industry-standard security measures including 256-bit SSL encryption. We do not sell personal data to third parties. You have the right to access, rectify, or erase your data at any time.',
  },
  {
    title: '9. Prohibited Activities',
    body: 'The following are strictly prohibited: use of automated systems or bots; collusion with other players; fraud or identity misrepresentation; money laundering or any other illegal activity; creating multiple accounts; exploiting software bugs.',
  },
  {
    title: '10. Limitation of Liability',
    body: 'To the maximum extent permitted by law, Veloria Casino disclaims all liability for indirect, incidental, special, or consequential damages arising from use of the platform. Our total liability shall not exceed the amount deposited by you in the 30 days prior to the claim.',
  },
  {
    title: '11. Governing Law',
    body: 'These Terms are governed by the laws of Malta and any disputes shall be subject to the exclusive jurisdiction of the Maltese courts. Alternative dispute resolution is available through the relevant gaming authority.',
  },
  {
    title: '12. Amendments',
    body: 'We reserve the right to modify these Terms at any time. Material changes will be notified via email or prominent site notice at least 14 days before taking effect. Continued use of the site after changes constitutes acceptance.',
  },
];
---

<PageLayout {...seo} locale={locale} current="/en/terms/">
  <div class="container py-8 md:py-14 max-w-3xl">
    <Breadcrumbs items={[{ label: 'Home', href: '/en/' }, { label: 'Terms & Conditions', href: '/en/terms/' }]} locale={locale} />

    <article class="mt-8">
      <h1 class="text-headline text-[var(--color-text-primary)] mb-2">Terms & Conditions</h1>
      <p class="text-xs text-[var(--color-text-muted)] mb-8">Last updated: 1 January 2026 · Demo prototype only</p>

      <div class="space-y-8">
        {sections.map(({ title, body }) => (
          <div>
            <h2 class="text-base font-bold text-[var(--color-text-primary)] mb-2">{title}</h2>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{body}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 p-4 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)]" role="note">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          These Terms and Conditions are fictional and form part of a UI prototype demonstration only. Veloria Casino does not operate as a real casino. No real money, gambling services, or legal obligations exist.
        </p>
      </div>
    </article>
  </div>
</PageLayout>
