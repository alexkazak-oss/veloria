---
import Breadcrumbs from '../../../components/layout/Breadcrumbs.astro'
import { ProviderCard } from '../../../components/widgets/ProviderCard'
import { providers } from '../../../data/providers'
import type { Locale } from '../../../i18n/index'
import { useTranslations } from '../../../i18n/index'
import PageLayout from '../../../layouts/PageLayout.astro'
import { buildBreadcrumbJsonLd, buildSEO } from '../../../lib/seo'

const locale = 'en' as Locale;
const t      = useTranslations(locale);

const seo = buildSEO({
  title       : 'Game Providers — Veloria Casino',
  description : `Browse all ${providers.length} game providers at Veloria Casino. Discover NovaSpin, LiveArena, AurumPlay and more top studios.`,
  canonical   : 'https://veloria.casino/en/providers/',
  locale,
  siteName    : 'Veloria Casino',
});

const breadcrumbLd = buildBreadcrumbJsonLd(
  [
    { label: 'Home',      url: 'https://veloria.casino/en/' },
    { label: 'Providers', url: 'https://veloria.casino/en/providers/' },
  ],
);
---

<PageLayout {...seo} locale={locale} current="/en/providers/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <div class="container py-8 md:py-12">
    <Breadcrumbs
      items={[
        { label: 'Home',      href: '/en/' },
        { label: 'Providers', href: '/en/providers/' },
      ]}
      locale={locale}
    />

    <div class="mt-6 mb-8">
      <h1 class="text-headline text-[var(--color-text-primary)] mb-2">{t.nav.providers}</h1>
      <p class="text-[var(--color-text-secondary)]">
        Meet the studios behind every game you love on Veloria.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {providers.map((provider) => (
        <ProviderCard provider={provider} locale={locale} client:idle />
      ))}
    </div>
  </div>
</PageLayout>
