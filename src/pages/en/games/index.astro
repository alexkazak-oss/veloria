---
import Breadcrumbs from '../../../components/layout/Breadcrumbs.astro'
import GameCatalog from '../../../components/widgets/GameCatalog'
import type { Locale } from '../../../i18n/index'
import { useTranslations } from '../../../i18n/index'
import PageLayout from '../../../layouts/PageLayout.astro'
import { buildBreadcrumbJsonLd, buildSEO } from '../../../lib/seo'

const locale = 'en' as Locale;
const t      = useTranslations(locale);

const seo = buildSEO({
  title       : 'All Games — Veloria Casino',
  description : 'Browse 500+ slots, live casino tables, jackpots, crash games and more at Veloria Casino. Filter by category, provider, and RTP.',
  canonical   : 'https://veloria.casino/en/games/',
  locale,
  siteName    : 'Veloria Casino',
});

const breadcrumbLd = buildBreadcrumbJsonLd(
  [
    { label: 'Home',  url: 'https://veloria.casino/en/' },
    { label: 'Games', url: 'https://veloria.casino/en/games/' },
  ],
);
---

<PageLayout {...seo} locale={locale} current="/en/games/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <div class="container py-8 md:py-12">
    <Breadcrumbs
      items={[
        { label: 'Home',  href: '/en/' },
        { label: 'Games', href: '/en/games/' },
      ]}
      locale={locale}
    />

    <div class="mt-6 mb-8">
      <h1 class="text-headline text-[var(--color-text-primary)] mb-2">{t.nav.games}</h1>
      <p class="text-[var(--color-text-secondary)]">
        Browse all 500+ games — slots, live casino, jackpots and more.
      </p>
    </div>

    <GameCatalog locale={locale} client:load />
  </div>
</PageLayout>
